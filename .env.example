# Google Analytics 4 (injected by src/lib/analytics.ts)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Set to "false" to disable all analytics/pixel injection in dev or test
# VITE_ANALYTICS_ENABLED=false

# Meta Pixel (optional — add when ready)
# VITE_META_PIXEL_ID=your-meta-pixel-id

# TikTok Pixel (optional — add when ready)
# VITE_TIKTOK_PIXEL_ID=your-tiktok-pixel-id

# LinkedIn Insight Tag (optional — add when ready for retargeting)
# VITE_LINKEDIN_PARTNER_ID=your-linkedin-partner-id

# Calendly — used for booking CTAs across the site
# VITE_CALENDLY_URL=https://calendly.com/alphaspeedai/30min

# Supabase — used for analytics events and Instagram feed (published_posts table)
# Run supabase/migrations/001_analytics_events.sql and 002_published_posts.sql in SQL Editor
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
